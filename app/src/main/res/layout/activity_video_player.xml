<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <com.fam4k007.videoplayer.player.CustomMPVView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:fitsSystemWindows="false" />

    <!-- 弹幕视图 - 覆盖在视频播放器上方 -->
    <com.fam4k007.videoplayer.danmaku.DanmakuPlayerView
        android:id="@+id/danmakuView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <!-- 点击区域，用于显示/隐藏控制面板 -->
    <View
        android:id="@+id/clickArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- 加载动画 -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

    <!-- 顶部控制面板已由 Compose TopControlPanel 接管 -->
    <!-- 以下为已移除的 topInfoPanel 占位，勿恢复 -->
    <LinearLayout
        android:id="@+id/topInfoPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:background="@android:color/transparent"
        android:visibility="gone">

        <!-- 实际内容区域 -->
        <LinearLayout
            android:id="@+id/topInfoContentRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/transparent"
            android:padding="8dp">

            <!-- 返回按钮 -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:tint="#FFFFFF"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="8dp" />

            <!-- 左侧区域:标题(占1/2宽度) -->
            <FrameLayout
                android:id="@+id/titleClickArea"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="4dp">
                
                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="视频文件名"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="0.85" />
            </FrameLayout>

            <!-- 右侧区域:状态+按钮(占1/2宽度,预留导航栏空间) -->
            <LinearLayout
                android:id="@+id/topRightPanel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:layout_marginEnd="60dp">

                <!-- 电量和时间显示（向左移动，给字幕按钮留空间） -->
                <LinearLayout
                    android:id="@+id/topStatusContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:orientation="vertical"
                    android:gravity="end|center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvBattery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12:00"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <!-- 字幕按钮（新增） -->
                <ImageView
                    android:id="@+id/btnSubtitle"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:tint="#FFFFFF"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="4dp" />

                <!-- 弹幕按钮（新增） -->
                <ImageView
                    android:id="@+id/btnDanmaku"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:tint="#FFFFFF"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="4dp" />

                <!-- 画面比例按钮 -->
                <ImageView
                    android:id="@+id/btnAspectRatio"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:tint="#FFFFFF"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="4dp" />

                <!-- 锁定按钮 -->
                <ImageView
                    android:id="@+id/btnLock"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:tint="#FFFFFF"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="6dp" />

                <!-- 更多选项按钮 -->
                <ImageView
                    android:id="@+id/btnMore"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:tint="#FFFFFF"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>


    <!-- 恢复播放提示 -->
    <LinearLayout
        android:id="@+id/resumePlaybackPrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:background="#66000000"
        android:orientation="horizontal"
        android:padding="16dp"
        android:elevation="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvResumeMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已为您恢复上次播放进度，是否从头播放？ "
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvResumeConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="确定"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- 竖屏悬浮按钮：超分辨率（左侧中间） -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAnime4KFloat"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:minWidth="80dp"
        android:text="超分辨率"
        android:textSize="12sp"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@android:color/transparent"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="14dp"
        android:layout_marginBottom="122dp"
        android:visibility="gone" />

    <!-- 竖屏悬浮按钮：旋转/切换布局（右侧中间） -->
    <ImageView
        android:id="@+id/btnRotateFloat"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_rotate"
        android:tint="#FFFFFF"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="122dp"
        android:visibility="gone" />

    <!-- 截图状态指示器 -->
    <include
        android:id="@+id/screenshotStatusContainer"
        layout="@layout/view_screenshot_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="120dp" />

</RelativeLayout>
