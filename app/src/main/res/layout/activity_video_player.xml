<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <com.fam4k007.videoplayer.player.CustomMPVView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:fitsSystemWindows="false" />

    <!-- 弹幕视图 - 覆盖在视频播放器上方 -->
    <com.fam4k007.videoplayer.danmaku.DanmakuPlayerView
        android:id="@+id/danmakuView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true" />

    <!-- 点击区域，用于显示/隐藏控制面板 -->
    <View
        android:id="@+id/clickArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- 加载动画 -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

    <!-- 恢复播放提示 -->
    <LinearLayout
        android:id="@+id/resumePlaybackPrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:background="#66000000"
        android:orientation="horizontal"
        android:padding="16dp"
        android:elevation="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvResumeMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已为您恢复上次播放进度，是否从头播放？ "
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvResumeConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="确定"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- 竖屏悬浮按钮：超分辨率（左侧中间） -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAnime4KFloat"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:minWidth="80dp"
        android:text="超分辨率"
        android:textSize="12sp"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@android:color/transparent"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="14dp"
        android:layout_marginBottom="122dp"
        android:visibility="gone" />

    <!-- 竖屏悬浮按钮：旋转/切换布局（右侧中间） -->
    <ImageView
        android:id="@+id/btnRotateFloat"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_rotate"
        android:tint="#FFFFFF"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="122dp"
        android:visibility="gone" />

    <!-- 截图状态指示器 -->
    <include
        android:id="@+id/screenshotStatusContainer"
        layout="@layout/view_screenshot_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="120dp" />

</RelativeLayout>
