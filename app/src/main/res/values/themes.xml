<resources>
    <!-- ==================== 基础主题 ==================== -->
    <style name="Theme.VideoPlayer.Base" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- ==================== 默认主题 ==================== -->
    <style name="Theme.VideoPlayer.BluePurple" parent="Theme.VideoPlayer.Base">
        <!-- Material Design 标准属性 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/text_white</item>
        <item name="colorSurface">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>

        <!-- dialog_selection_item.xml 仍在使用的属性 -->
        <item name="colorDialogText">@color/text_primary</item>
    </style>

    <!-- ==================== 默认主题别名 ==================== -->
    <style name="Theme.VideoPlayer" parent="Theme.VideoPlayer.BluePurple" />
</resources>
